# String de conexão do MongoDB Atlas
MONGO_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/cinetron?retryWrites=true&w=majority

# Chave secreta para JWT — gere uma string aleatória longa e segura
JWT_SECRET=troque_por_uma_string_muito_segura_e_longa_aqui

# Tempo de expiração do token
JWT_EXPIRES=30d

# URL do frontend (para CORS) — use a URL do seu deploy Vercel
FRONTEND_URL=use_a_url_do_seu_deploy
